APP_NAME="Inventaire des artistes neuchâtelois·es"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr
APP_FAKER_LOCALE=fr_FR

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# Pre-launch gate — controls who can access the site.
# 'off'    : full public access (normal production)
# 'strict' : only APP_PRELAUNCH_IP_WHITELIST can enter (pre-pre-launch)
# 'v1'     : whitelist gets full access; others can only reach registration + admin
APP_PRELAUNCH_MODE=off
APP_PRELAUNCH_IP_WHITELIST=

# Comma-separated list of trusted reverse proxy IPs (or * to trust all).
# Set to the actual proxy IP(s) in production so X-Forwarded-For resolves correctly.
APP_TRUSTED_PROXIES=*

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"
# Staging catch-all: redirect every outgoing mail to this address
#MAIL_TO_ADDRESS=dev@example.com
#MAIL_TO_NAME="Dev Catch-All"
# Staging subject prefix (e.g. "[STAGING] - ")
#MAIL_SUBJECT_PREFIX=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
